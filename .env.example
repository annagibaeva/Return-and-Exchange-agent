ANTHROPIC_API_KEY=

# REFERENCE_DATE=2026-06-15  # freeze policy clock for eval stability (defaults to today)

# Optional API key for /chat, /reset, and /verify. When set, callers must send
# X-API-Key with this value. When unset, auth is skipped (local dev).
CHAT_API_KEY=

# Server bind address (defaults to 127.0.0.1). Set HOST=0.0.0.0 to listen on all interfaces.
# HOST=127.0.0.1

# Conversation store bounds (app.py in-memory sessions).
# MAX_CONVERSATIONS=100
# SESSION_TTL_SECONDS=3600

# Flask session signing key (random per-process if unset).
# FLASK_SECRET_KEY=
